# =============================================================================
# Ollama — local open-source LLM + embedding service
# Install: https://ollama.com
# Pull models: ollama pull llama3.2 && ollama pull nomic-embed-text
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434

# Chat model used by the synthesizer agent
OLLAMA_SYNTH_MODEL=llama3.2

# Embedding model (nomic-embed-text produces 768-dimensional vectors)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# DocumentDB OSS — MongoDB-compatible document database
# Start with Docker:
#   docker run -dt -p 10260:10260 \
#     -e USERNAME=docdbuser -e PASSWORD=Admin100! \
#     ghcr.io/microsoft/documentdb/documentdb-local:latest
# =============================================================================
DOCUMENTDB_CONNECTION_STRING=mongodb://docdbuser:Admin100!@localhost:10260/?tls=true&tlsAllowInvalidCertificates=true&authMechanism=SCRAM-SHA-256

# =============================================================================
# Database / collection names (defaults shown)
# =============================================================================
DOCUMENTDB_DATABASE=Hotels
DOCUMENTDB_COLLECTION=hotel_data

# =============================================================================
# Agent behaviour (optional overrides)
# =============================================================================

# Natural-language query sent to the hotel recommendation agent
QUERY=quintessential lodging near running trails, eateries, and retail

# Number of candidate hotels the planner fetches from the vector store
NEAREST_NEIGHBORS=5

# =============================================================================
# Vector index configuration (used during npm run upload)
# =============================================================================

# Algorithm: vector-ivf (default) | vector-hnsw | vector-diskann
VECTOR_INDEX_ALGORITHM=vector-ivf

# Must match the embedding model output dimension
# nomic-embed-text = 768 | mxbai-embed-large = 1024 | all-minilm = 384
EMBEDDING_DIMENSIONS=768

# Similarity metric: COS (cosine) | L2 (euclidean) | IP (inner product)
VECTOR_SIMILARITY=COS

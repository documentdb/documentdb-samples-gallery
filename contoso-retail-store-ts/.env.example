# Server port
PORT=3000

# Node environment
NODE_ENV=development

# Primary DocumentDB connection (local or Azure — the ONLY thing you change between Act 1 targets)
# Local (Docker):
DOCUMENTDB_URI=mongodb://docdbuser:documentdb@localhost:10260/?tls=true&tlsAllowInvalidCertificates=true&authMechanism=SCRAM-SHA-256&directConnection=true
# Azure DocumentDB (vCore-based):
# DOCUMENTDB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256

# Database name
DB_NAME=retaildb

# Ollama embedding service URL
OLLAMA_URL=http://localhost:11434

# Ollama embedding model
OLLAMA_MODEL=nomic-embed-text

# Embedding dimensions (must match the model and the vector index)
EMBEDDING_DIMENSIONS=768

# --- Act 2: Hybrid Replication URIs ---
PRIMARY_URI=mongodb://docdbuser:documentdb@localhost:10260/?tls=true&tlsAllowInvalidCertificates=true&authMechanism=SCRAM-SHA-256&directConnection=true
HQ_REPLICA_URI=mongodb://docdbuser:documentdb@localhost:10261/?tls=true&tlsAllowInvalidCertificates=true&authMechanism=SCRAM-SHA-256&directConnection=true
WAREHOUSE_REPLICA_URI=mongodb://docdbuser:documentdb@localhost:10262/?tls=true&tlsAllowInvalidCertificates=true&authMechanism=SCRAM-SHA-256&directConnection=true
